# Application
NODE_ENV=development
APP_NAME=pwa-torneios
APP_PORT=3000
APP_URL=http://localhost

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pwa_torneios
POSTGRES_USER=pwa_torneios
POSTGRES_PASSWORD=pwa_torneios_dev
DATABASE_URL=postgresql://pwa_torneios:pwa_torneios_dev@postgres:5432/pwa_torneios

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=change-me-in-local-env
JWT_EXPIRES_IN=1d

# Traefik / Local routing
TRAEFIK_DASHBOARD_PORT=8080
API_HOST=api.localhost
WEB_HOST=app.localhost

# Logs
LOG_LEVEL=debug
